<div style="text-align:center;font-size:18px;font-weight:bold;margin-bottom:16px;">销货单</div><table><tr><td>订单编号: {{orderNo}}</td><td>日期: {{orderDate}}</td></tr><tr><td>客户: {{customerName}}</td><td>地址: {{customerAddress}}</td></tr></table><br><table><thead><tr><th>产品</th><th>数量</th><th>单价</th><th>金额</th></tr></thead><tbody>{{#each items}}<tr><td>{{this.productName}}</td><td class="text-center">{{this.quantity}}</td><td class="text-right">{{this.unitPrice}}</td><td class="text-right">{{this.amount}}</td></tr>{{/each}}</tbody></table><br><p class="text-right">合计: {{totalAmount}}</p>